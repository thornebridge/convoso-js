{
  "name": "convoso-js",
  "version": "0.1.0",
  "description": "Unofficial TypeScript SDK for the Convoso API",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run build && npm test"
  },
  "keywords": [
    "convoso",
    "api",
    "sdk",
    "call-center",
    "dialer",
    "leads",
    "typescript"
  ],
  "author": "Thornebridge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thornebridge/convoso-js.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
